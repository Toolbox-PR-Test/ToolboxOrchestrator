name: Register app

on:
  workflow_dispatch:
    inputs:
      app:
        description: "App repo to register"
        type: choice
        required: true
        options:
          - FacCon

permissions:
  contents: write
  pull-requests: write

jobs:
  register:
    runs-on: ubuntu-latest
    env:
      OWNER: Toolbox-PR-Test
      GH_TOKEN: ${{ github.token }}
    steps:
      - uses: actions/checkout@v4

      - name: Fetch app manifest
        run: |
          curl -fsSL "https://raw.githubusercontent.com/${OWNER}/${{ inputs.app }}/main/plugin.json" -o app-plugin.json
          jq . app-plugin.json   # fails if not valid JSON

      - name: Stage manifest
        id: m
        run: |
          slug=$(jq -r .slug app-plugin.json)
          echo "slug=$slug" >> "$GITHUB_OUTPUT"
          mkdir -p manifests
          cp app-plugin.json "manifests/${slug}.json"

      - name: Open release PR
        run: |
          slug="${{ steps.m.outputs.slug }}"
          branch="release/${slug}-${{ github.run_number }}"
          git config user.name  "toolbox-bot"
          git config user.email "toolbox-bot@users.noreply.github.com"
          git checkout -b "$branch"
          git add "manifests/${slug}.json"
          git commit -m "register: ${slug} (from ${{ inputs.app }})"
          git push -u origin "$branch"
          gh pr create --base main --head "$branch" \
            --title "Release: ${slug}" \
            --body "Registering ${slug} from ${{ inputs.app }}. Approve to publish, close to reject."
